{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema.role-card",
  "title": "Role Card Schema",
  "type": "object",
  "description": "Schema for a Role Card — a constrained role definition with persona and operational layers.",
  "properties": {
    "persona": {
      "type": "object",
      "description": "Optional narrative wrapper for recall and usability.",
      "properties": {
        "displayName": { "type": "string" },
        "personality": { "type": "string" },
        "background": { "type": "string" },
        "image": { "type": "string" },
        "mission": { "type": "string" },
        "responsibilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "deliverables": {
          "type": "array",
          "items": { "type": "string" }
        },
        "weakness": { "type": "string" }
      },
      "required": ["displayName", "mission", "responsibilities", "deliverables", "weakness"]
    },
    "roleCard": {
      "type": "object",
      "description": "Authoritative execution model.",
      "properties": {
        "name": { "type": "string" },
        "alias": { "type": "string" },
        "archetypeFamily": {
          "type": "string",
          "enum": ["Analyst", "Builder", "Operator", "Truth-Teller", "Reviewer", "Facilitator"]
        },
        "level": {
          "type": "string",
          "enum": ["Beginner", "Pro", "Legendary"]
        },
        "primaryType": { "type": "string" },
        "secondaryType": { "type": "string" },
        "operationalQuestion": { "type": "string" },
        "activationCondition": { "type": "string" },
        "authority": { "type": "string" },
        "signatureMove": { "type": "string" },
        "artifactProduced": {
          "type": "array",
          "items": { "type": "string" }
        },
        "specialAbility": { "type": "string" },
        "weakness": { "type": "string" },
        "synergyBoost": { "type": "string" },
        "xpGainCondition": { "type": "string" },
        "skillRatings": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 7
          }
        },
        "raci": {
          "type": "object",
          "properties": {
            "accountable": { "type": "array", "items": { "type": "string" } },
            "responsible": { "type": "array", "items": { "type": "string" } },
            "consulted": { "type": "array", "items": { "type": "string" } },
            "informed": { "type": "array", "items": { "type": "string" } }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "system": { "type": "string" },
            "version": { "type": "string" },
            "year": { "type": "integer" }
          }
        }
      },
      "required": [
        "name", "alias", "archetypeFamily", "level",
        "primaryType", "operationalQuestion", "activationCondition",
        "authority", "signatureMove", "artifactProduced", "weakness"
      ]
    }
  },
  "required": ["roleCard"]
}
