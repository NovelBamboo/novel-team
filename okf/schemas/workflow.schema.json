{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "schema.workflow",
  "title": "Workflow Schema",
  "type": "object",
  "description": "Schema for an ordered workflow with stages and gates.",
  "properties": {
    "id": { "type": "string" },
    "title": { "type": "string" },
    "type": { "const": "workflow" },
    "entry_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string" },
          "produces": {
            "type": "array",
            "items": { "type": "string" }
          },
          "authority": { "type": "string" }
        },
        "required": ["role"]
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "condition": { "type": "string" },
          "approving_role": { "type": "string" }
        },
        "required": ["name", "condition"]
      }
    },
    "required_artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "exit_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "failure_recovery": {
      "type": "object",
      "properties": {
        "on_reject": { "type": "string" },
        "on_block": { "type": "string" },
        "escalation_path": { "type": "string" }
      }
    }
  },
  "required": ["id", "title", "type", "stages", "gates"]
}
